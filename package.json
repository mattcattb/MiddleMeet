{
  "name": "matty-stack",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --env-file=.env run --filter '*' dev",
    "dev:server": "bun --env-file=.env run --filter @matty-stack/server dev",
    "dev:web": "bun --env-file=.env run --filter @matty-stack/web dev",
    "build": "bun --env-file=.env run --filter '*' build",
    "db:generate": "bun --env-file=.env run --filter @matty-stack/server db:generate",
    "db:migrate": "bun --env-file=.env run --filter @matty-stack/server db:migrate",
    "db:studio": "bun --env-file=.env run --filter @matty-stack/server db:studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  }
}
